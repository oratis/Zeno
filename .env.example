# Zeno · 环境变量样例。复制为 .env（本地）并填值。.env 已被 .gitignore 忽略。

# Postgres（需 pgvector 扩展）
DATABASE_URL=postgres://postgres:postgres@localhost:5432/zeno

# Anthropic / Claude（经 AI Gateway 分级调用，见 app/src/lib/ai/gateway.ts）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 嵌入向量提供方（可选；缺省则检索退化为结构化+关键词）
# Anthropic 不提供 embeddings，推荐 Voyage AI（voyage-3，1024 维，与 schema 对齐）
VOYAGE_API_KEY=

# Amazon Associates 归因（接入 PA-API 前，履约链接用此 tag 占位）
AFFILIATE_TAG=zeno-20

# 目标市场（MVP：US）
ZENO_MARKET=US
